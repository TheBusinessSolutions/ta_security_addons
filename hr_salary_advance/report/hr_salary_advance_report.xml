<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         REPORT — Employee Advance Statement
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="action_report_hr_salary_advance" model="ir.actions.report">
        <field name="name">Advance Statement</field>
        <field name="model">hr.salary.advance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_salary_advance.report_hr_salary_advance_template</field>
        <field name="report_file">hr_salary_advance.report_hr_salary_advance_template</field>
        <field name="binding_model_id" ref="model_hr_salary_advance"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Employee Statement Report (from Ledger) -->
    <record id="action_report_hr_advance_statement" model="ir.actions.report">
        <field name="name">Employee Advance Statement</field>
        <field name="model">hr.advance.ledger.line</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_salary_advance.report_hr_advance_statement_template</field>
        <field name="report_file">hr_salary_advance.report_hr_advance_statement_template</field>
        <field name="binding_model_id" ref="model_hr_advance_ledger_line"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
