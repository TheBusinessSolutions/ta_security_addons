<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Advance Reference Numbers -->
        <record id="seq_hr_salary_advance" model="ir.sequence">
            <field name="name">Salary Advance</field>
            <field name="code">hr.salary.advance</field>
            <field name="prefix">ADV/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!--
            NOTE - SAR Payslip Input (hr_payroll_community):
            hr_payroll_community has no input type model (that is Enterprise-only).
            Inputs are plain hr.payslip.input lines added directly on the payslip.

            To deduct a salary advance, HR adds a line in the payslip
            "Input Lines" tab:
                Name   : Salary Advance Return
                Code   : SAR
                Amount : amount to deduct this month

            The SAR salary rule reads it via: inputs.SAR.amount
        -->

    </data>
</odoo>
