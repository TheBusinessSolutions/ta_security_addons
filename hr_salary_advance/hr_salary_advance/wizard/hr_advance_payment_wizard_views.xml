<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         CASH REPAYMENT WIZARD — FORM VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_advance_payment_wizard_form" model="ir.ui.view">
        <field name="name">hr.advance.payment.wizard.form</field>
        <field name="model">hr.advance.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Advance Repayment">
                <sheet>
                    <!-- Info Banner -->
                    <div class="alert alert-info mb-3">
                        <strong>Register a Cash or Bank Repayment</strong><br/>
                        This will post a journal entry:
                        <strong>DR Cash/Bank | CR Advance Account</strong>
                        and reduce the employee's outstanding advance balance.
                    </div>

                    <group string="Advance Information">
                        <group>
                            <field name="advance_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="outstanding_balance" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Payment Details">
                        <group>
                            <field name="date" required="1"/>
                            <field name="amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group>
                            <field name="journal_id"
                                   domain="[('type', 'in', ['cash', 'bank'])]"/>
                            <field name="advance_account_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Notes">
                        <field name="notes"
                               nolabel="1"
                               placeholder="Optional: payment reference, cheque number, etc."/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_confirm_payment"
                            string="Confirm Payment"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
