<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Advance Reference Numbers -->
        <record id="seq_hr_salary_advance" model="ir.sequence">
            <field name="name">Salary Advance</field>
            <field name="code">hr.salary.advance</field>
            <field name="prefix">ADV/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- SAR Input Type for Payslip Other Inputs -->
        <!-- This is the input type HR uses in the payslip to specify
             the salary advance deduction amount for this period -->
        <record id="hr_payslip_input_type_sar" model="hr.payslip.input.type">
            <field name="name">Salary Advance Return</field>
            <field name="code">SAR</field>
            <field name="country_id" eval="False"/>
        </record>

    </data>
</odoo>
