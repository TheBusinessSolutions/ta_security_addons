<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         PAYSLIP FORM — Inherit to show advance info and outstanding balance
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_payslip_advance_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.form.advance.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">

            <!-- Add advance outstanding balance info below employee/period fields -->
            <xpath expr="//field[@name='employee_id']" position="after">
                <!-- Show outstanding balance banner if employee has advances -->
                <field name="currency_id" invisible="1"/>
                <field name="advance_outstanding" invisible="1"/>
            </xpath>

            <!-- Add a dedicated Advance tab in the payslip notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Salary Advance" name="salary_advance">
                    <div class="alert alert-info mb-3" invisible="advance_outstanding == 0">
                        <strong>💰 Employee Total Outstanding Advance Balance: </strong>
                        <field name="advance_outstanding"
                               widget="monetary"
                               options="{'currency_field': 'currency_id'}"/>
                        <br/>
                        <span class="text-muted small">
                            To deduct from this payslip, add a line in the
                            <strong>Other Inputs</strong> tab with code <strong>SAR</strong>
                            and enter the amount to deduct this month.
                        </span>
                    </div>

                    <div class="alert alert-success mb-3" invisible="advance_outstanding != 0">
                        <strong>✅ No outstanding advance balance for this employee.</strong>
                    </div>

                    <!-- Advance deductions applied via this payslip -->
                    <field name="advance_ledger_line_ids" readonly="1">
                        <list string="Advance Deductions (This Payslip)" editable="false">
                            <field name="date"/>
                            <field name="advance_id"/>
                            <field name="description"/>
                            <field name="amount" sum="Total Deducted"/>
                            <field name="currency_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
