<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         LEDGER LINE SUB-VIEW for use inside hr.payslip (payslip tab)
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_advance_ledger_payslip_sublist" model="ir.ui.view">
        <field name="name">hr.advance.ledger.line.payslip.sublist</field>
        <field name="model">hr.advance.ledger.line</field>
        <field name="arch" type="xml">
            <list string="Advance Deductions (This Payslip)"
                  create="false"
                  edit="false"
                  delete="false">
                <field name="date"/>
                <field name="advance_id" string="Advance Ref"/>
                <field name="description"/>
                <field name="amount" sum="Total Deducted"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         PAYSLIP FORM — Inherit to show advance info
         Compatible with hr_payroll_community view IDs
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_payslip_advance_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.form.advance.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll_community.hr_payslip_view_form"/>
        <field name="arch" type="xml">

            <!-- Inject hidden currency field after employee_id -->
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="advance_currency_id" invisible="1"/>
                <field name="advance_outstanding" invisible="1"/>
            </xpath>

            <!-- Add Advance tab inside the notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Salary Advance" name="salary_advance">

                    <!-- Outstanding Balance Info Box -->
                    <div class="alert alert-warning mb-3"
                         invisible="advance_outstanding == 0">
                        <strong>&#9888; Employee Outstanding Advance Balance: </strong>
                        <field name="advance_outstanding"
                               widget="monetary"
                               options="{'currency_field': 'advance_currency_id'}"/>
                        <br/>
                        <span class="text-muted" style="font-size:0.9em;">
                            To deduct this month, go to the
                            <strong>Input Lines</strong> tab and add a line:
                            <br/>
                            &#8226; <strong>Code: SAR</strong> |
                            Name: Salary Advance Return |
                            Amount: amount to deduct
                        </span>
                    </div>

                    <div class="alert alert-success mb-3"
                         invisible="advance_outstanding != 0">
                        <strong>&#10003; No outstanding advance balance for this employee.</strong>
                    </div>

                    <!-- Advance deductions linked to this payslip -->
                    <field name="advance_ledger_line_ids"
                           readonly="1"
                           views="[(ref('hr_salary_advance.view_hr_advance_ledger_payslip_sublist'), 'list')]"/>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
