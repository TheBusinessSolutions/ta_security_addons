<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         SALARY ADVANCE — FORM VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_salary_advance_form" model="ir.ui.view">
        <field name="name">hr.salary.advance.form</field>
        <field name="model">hr.salary.advance</field>
        <field name="arch" type="xml">
            <form string="Salary Advance Request">

                <!-- Status Bar -->
                <header>
                    <button name="action_submit"
                            string="Submit for Approval"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="account.group_account_manager"/>

                    <button name="action_disburse"
                            string="Disburse Advance"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approved'"
                            groups="account.group_account_manager"/>

                    <button name="action_register_cash_payment"
                            string="Register Cash Repayment"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'disbursed'"
                            groups="account.group_account_manager"/>

                    <button name="action_refuse"
                            string="Refuse"
                            type="object"
                            class="btn-danger"
                            invisible="state not in ('submitted', 'approved')"
                            groups="account.group_account_manager"/>

                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'refused'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved,disbursed"/>
                </header>

                <sheet>
                    <!-- Outstanding Balance Banner — shown when employee selected -->
                    <div class="alert alert-warning mb-3"
                         invisible="employee_total_outstanding == 0 or not employee_id">
                        <strong>⚠ Employee Outstanding Balance: </strong>
                        <field name="employee_total_outstanding"
                               widget="monetary"
                               options="{'currency_field': 'currency_id'}"/>
                        <span class="ms-2 text-muted">
                            (Total unpaid advances across all requests)
                        </span>
                    </div>

                    <div class="oe_title mb-3">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"
                                   readonly="state not in ('draft', 'refused')"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>

                        <group string="Advance Details">
                            <field name="date"
                                   readonly="state not in ('draft', 'refused')"/>
                            <field name="amount"
                                   readonly="state not in ('draft', 'refused')"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Accounting Configuration"
                           invisible="state not in ('draft', 'refused', 'submitted', 'approved')">
                        <group>
                            <field name="advance_account_id"
                                   readonly="state not in ('draft', 'refused', 'submitted', 'approved')"/>
                        </group>
                        <group>
                            <field name="journal_id"
                                   readonly="state not in ('draft', 'refused', 'submitted', 'approved')"/>
                        </group>
                    </group>

                    <!-- Readonly accounting info after disburse -->
                    <group string="Accounting Configuration" invisible="state not in ('disbursed',)">
                        <group>
                            <field name="advance_account_id" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="journal_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Reason">
                        <field name="reason"
                               nolabel="1"
                               placeholder="Reason for advance request..."
                               readonly="state not in ('draft', 'refused')"/>
                    </group>

                    <!-- Balance Summary (visible after disburse) -->
                    <group string="Repayment Summary" invisible="state != 'disbursed'">
                        <group>
                            <field name="amount" string="Advance Amount" readonly="1"/>
                            <field name="total_repaid" readonly="1"/>
                        </group>
                        <group>
                            <field name="outstanding_balance" readonly="1"/>
                        </group>
                    </group>

                    <!-- Approval Info -->
                    <group string="Approval Information"
                           invisible="state not in ('approved', 'disbursed', 'refused')">
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="disbursed_by" readonly="1"
                                   invisible="state != 'disbursed'"/>
                            <field name="disbursed_date" readonly="1"
                                   invisible="state != 'disbursed'"/>
                        </group>
                    </group>

                    <!-- Ledger Lines Tab -->
                    <notebook invisible="state != 'disbursed'">
                        <page string="Repayment History" name="ledger_lines">
                            <field name="ledger_line_ids"
                                   readonly="1"
                                   views="[(ref('hr_salary_advance.view_hr_advance_ledger_sublist'), 'list')]"/>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         SALARY ADVANCE — LIST VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_salary_advance_list" model="ir.ui.view">
        <field name="name">hr.salary.advance.list</field>
        <field name="model">hr.salary.advance</field>
        <field name="arch" type="xml">
            <list string="Salary Advances"
                  decoration-success="state == 'disbursed'"
                  decoration-warning="state == 'approved'"
                  decoration-info="state == 'submitted'"
                  decoration-muted="state == 'refused'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="total_repaid" optional="show"/>
                <field name="outstanding_balance" optional="show"/>
                <field name="advance_account_id" optional="hide"/>
                <field name="journal_id" optional="hide"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         SALARY ADVANCE — SEARCH VIEW
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_hr_salary_advance_search" model="ir.ui.view">
        <field name="name">hr.salary.advance.search</field>
        <field name="model">hr.salary.advance</field>
        <field name="arch" type="xml">
            <search string="Search Salary Advances">
                <field name="name" string="Reference"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Pending Approval" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="filter_disbursed" string="Disbursed" domain="[('state', '=', 'disbursed')]"/>
                <filter name="filter_refused" string="Refused" domain="[('state', '=', 'refused')]"/>
                <separator/>
                <filter name="filter_outstanding" string="Has Outstanding Balance"
                        domain="[('outstanding_balance', '&gt;', 0)]"/>
                <separator/>
                <filter name="filter_my_dept" string="My Department"
                        domain="[('department_id.manager_id.user_id', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         ACTION — SALARY ADVANCE
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="action_hr_salary_advance" model="ir.actions.act_window">
        <field name="name">Salary Advances</field>
        <field name="res_model">hr.salary.advance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_salary_advance_search"/>
        <field name="context">{'search_default_filter_disbursed': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first salary advance request
            </p>
            <p>
                Request salary advances for employees. Finance Manager approval
                is required before disbursement.
            </p>
        </field>
    </record>

    <!-- Action: My Pending Approvals -->
    <record id="action_hr_salary_advance_pending" model="ir.actions.act_window">
        <field name="name">Pending Approval</field>
        <field name="res_model">hr.salary.advance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'submitted')]</field>
        <field name="search_view_id" ref="view_hr_salary_advance_search"/>
    </record>

</odoo>
