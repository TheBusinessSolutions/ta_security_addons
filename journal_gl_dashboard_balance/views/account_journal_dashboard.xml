<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_dashboard_gl_balance" model="ir.ui.view">
        <field name="name">account.journal.dashboard.gl.balance</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@id='dashboard_bank_cash_left']" position="inside">

                <div class="mt8 o_journal_gl_balance">

                    <button type="object"
                            name="action_open_gl_account"
                            class="btn btn-link p-0 text-muted">
                        GL Report <field name="gl_balance" widget="monetary"/>
                    </button>


                </div>

            </xpath>

        </field>
    </record>

</odoo>