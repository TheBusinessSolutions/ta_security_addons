<odoo>

    <record id="view_journal_dashboard_pro" model="ir.ui.view">
        <field name="name">journal.dashboard.pro</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@id='dashboard_bank_cash_left']" position="inside">

                <div class="mt8">

                    <div>
                        <strong>GL Balance:</strong>
                        <field name="gl_balance" widget="monetary"/>
                    </div>

                    <div>
                        <strong>Dashboard Balance:</strong>
                        <field name="dashboard_balance" widget="monetary"/>
                    </div>

                    <div>
                        <strong>Difference:</strong>
                        <field name="balance_difference" widget="monetary"/>
                    </div>

                </div>

            </xpath>

        </field>
    </record>

</odoo>