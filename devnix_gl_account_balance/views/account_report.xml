<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_account_view_tree" model="ir.ui.view">
            <field name="name">account_account_view_tree</field>
            <field name="model">account.account</field>
            <field name="arch" type="xml">
                <tree string="account_account_tree">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="current_balance"/>
                </tree>
            </field>
        </record>
        <record id="account_account_balance_action" model="ir.actions.act_window">
            <field name="name">GL</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.account</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="account_account_view_tree"/>
        </record>
        <record id="account_journal_kanban" model="ir.ui.view">
            <field name="name">account.journal.kanaban</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@id='dashboard_bank_cash_left']/*[1]" position="before">
                    <button type="object" name="action_open_gl_account" class="text-muted">GL Report</button>
                    <field name="gl_balance"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
